{
  "name": "network-sonar",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:backend dev:frontend",
    "dev:backend": "HOST=127.0.0.1 PORT=4173 npm --workspace backend run dev",
    "dev:frontend": "npm --workspace frontend run dev",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "npm --workspace frontend run build",
    "build:backend": "npm --workspace backend run build",
    "start": "NODE_ENV=production npm --workspace backend run start",
    "lint": "eslint .",
    "typecheck": "npm run typecheck:backend && npm run typecheck:frontend && tsc -p tsconfig.tests.json --noEmit",
    "typecheck:backend": "npm --workspace backend run typecheck",
    "typecheck:frontend": "npm --workspace frontend run typecheck",
    "test": "npm run test:unit && npm run test:contract && npm run test:integration",
    "test:unit": "vitest run tests/unit",
    "test:contract": "vitest run tests/contract",
    "test:integration": "vitest run tests/integration"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.1",
    "@types/node": "^22.14.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/supertest": "^6.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.24.0",
    "globals": "^16.0.0",
    "jsdom": "^26.0.0",
    "npm-run-all": "^4.1.5",
    "supertest": "^7.1.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.28.0",
    "vite": "^6.2.6",
    "vitest": "^3.1.1"
  }
}
